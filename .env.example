# API key for the embeddings model. Defaults to OpenAI embeddings
OPENAI_API_KEY=

# 검색 쿼리 확장: Ollama 먼저, 실패하면 OpenAI
QUERY_EXPANSION_LLM_BASE_URL=http://localhost:11434
QUERY_EXPANSION_LLM_PROVIDER=auto
QUERY_EXPANSION_LLM_MODEL=qwen3.5:9b
QUERY_EXPANSION_OPENAI_MODEL=gpt-5.4-mini

# AGENT_LLM_PROVIDER: Ollama 먼저, 실패하면 OpenAI
AGENT_LLM_BASE_URL=http://localhost:6000
AGENT_LLM_PROVIDER=auto
AGENT_LLM_MODEL=qwen3.5:122b
AGENT_LLM_OPENAI_MODEL=gpt-5.4

# LLM Wiki rebuild: Agentic RAG와 별도 모델 사용
WIKI_LLM_PROVIDER=ollama
WIKI_LLM_BASE_URL=http://host.docker.internal:7000
WIKI_LLM_MODEL=qwen3.5:35b
WIKI_LLM_TEMPERATURE=0

# PostgreSQL configuration
POSTGRES_HOST=llmwiki
POSTGRES_PORT=5432
POSTGRES_USER=llmwiki
POSTGRES_PASSWORD=llmwiki
POSTGRES_DB=llmwiki_rag_db

# CORS configuration. Must be a JSON array of strings
ALLOW_ORIGINS=["*"]

# Testing mode (set to true for simple authentication)
IS_TESTING=false

# API configuration
API_BASE_URL=http://localhost:8888

# Frontend configuration
NEXT_PUBLIC_API_URL=http://localhost:8888
NEXTAUTH_SECRET=langconnect-next-server-secret
NEXTAUTH_URL=http://localhost:3005

# MCP SSE Server configuration
SSE_PORT=8765
