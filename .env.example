# OpenAI API key for OpenAI LLM fallback paths
OPENAI_API_KEY=

# PostgreSQL configuration
POSTGRES_HOST=teddynote
POSTGRES_PORT=5432
POSTGRES_USER=teddynote
POSTGRES_PASSWORD=teddynote
POSTGRES_DB=teddynote_db

# CORS configuration. Must be a JSON array of strings
ALLOW_ORIGINS=["http://localhost:3005","http://localhost:3000"]

# Testing mode (set to true for simple authentication)
IS_TESTING=false

# API configuration
API_BASE_URL=http://localhost:8888

# Frontend configuration
NEXT_PUBLIC_API_URL=http://localhost:8888
NEXTAUTH_SECRET=langconnect-next-server-secret
NEXTAUTH_URL=http://localhost:3005

# MCP SSE Server configuration
SSE_PORT=8765

# Ollama configuration
OLLAMA_BASE_URL=http://localhost:5000

# Query expansion LLM configuration
QUERY_EXPANSION_OLLAMA_BASE_URL=http://localhost:5000
QUERY_EXPANSION_LLM_PROVIDER=auto
QUERY_EXPANSION_LLM_MODEL=qwen3.5:35b
QUERY_EXPANSION_LLM_TEMPERATURE=0
QUERY_EXPANSION_OPENAI_MODEL=gpt-5.4
QUERY_EXPANSION_OPENAI_TEMPERATURE=0

# Agentic RAG configuration
AGENT_OLLAMA_BASE_URL=http://localhost:5001
AGENT_LLM_PROVIDER=auto
AGENT_LLM_MODEL=qwen3.5:122b
AGENT_LLM_OPENAI_MODEL=gpt-5.4
AGENT_LLM_TEMPERATURE=0
AGENT_MAX_REWRITES=3
