%%{init: {
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Helvetica, Arial",
    "primaryColor": "#f5f7fa",
    "primaryBorderColor": "#c9d1d9",
    "lineColor": "#9aa4b2",
    "secondaryColor": "#eef2f7",
    "tertiaryColor": "#ffffff"
  }
}}%%
flowchart TD
    START(["START"])

    RETRIEVE["<b>retrieve</b><br/>Collection.search() call<br/>document search (semantic/keyword/hybrid)<br/><i>→ documents, steps update</i>"]

    GRADE_DOCS[["<b>grade_documents</b><br/>LLM evaluates relevance of each document<br/>binary score: yes / no<br/><i>→ relevant_documents, steps update</i>"]]

    ROUTE_GRADE{"<b>_route_after_grading</b><br/>determine if relevant documents exist"}

    REWRITE[["<b>rewrite_query</b><br/>LLM query rewriting<br/>vector search optimization<br/><i>→ question, query_rewrites,<br/>rewrite_count, steps update</i>"]]

    GENERATE[["<b>generate</b><br/>based on relevant document context<br/>LLM answer generation<br/><i>→ generation, steps update</i>"]]

    GRADE_GEN[["<b>grade_generation</b><br/>2-stage verification<br/>① Hallucination Check<br/>② Answer Quality Check<br/><i>→ steps update</i>"]]

    ROUTE_GEN{"<b>_route_after_generation_check</b><br/>check if last step<br/>contains PASSED"}

    MAXCHECK_GRADE{"rewrite_count<br/>< max_rewrites?"}
    MAXCHECK_GEN{"rewrite_count<br/>< max_rewrites?"}

    FORCED_GEN["Forced generation<br/><i>(max_rewrites reached,<br/>no relevant docs)</i>"]

    FORCED_END["Forced termination<br/><i>(max_rewrites reached,<br/>quality insufficient)</i>"]

    END_OK(["END<br/>Success"])
    END_FORCED(["END<br/>Forced termination"])

    START --> RETRIEVE
    RETRIEVE --> GRADE_DOCS
    GRADE_DOCS --> ROUTE_GRADE

    ROUTE_GRADE -->|"relevant_documents > 0"| GENERATE
    ROUTE_GRADE -->|"relevant_documents == 0"| MAXCHECK_GRADE

    MAXCHECK_GRADE -->|"Yes (retry possible)"| REWRITE
    MAXCHECK_GRADE -->|"No (limit reached)"| FORCED_GEN

    FORCED_GEN --> GENERATE
    GENERATE --> GRADE_GEN
    GRADE_GEN --> ROUTE_GEN

    ROUTE_GEN -->|"PASSED (Both checks passed)"| END_OK
    ROUTE_GEN -->|"FAILED (Check failed)"| MAXCHECK_GEN

    MAXCHECK_GEN -->|"Yes (retry possible)"| REWRITE
    MAXCHECK_GEN -->|"No (limit reached)"| FORCED_END
    FORCED_END --> END_FORCED

    REWRITE -->|"Loop back (re-run retrieve)"| RETRIEVE

    classDef module fill:#ffffff,stroke:#c9d1d9,stroke-width:1.5px,rx:12,ry:12,color:#1f2933
    classDef decision fill:#e3f2fd,stroke:#90caf9,stroke-width:1.5px,rx:12,ry:12
    classDef agent fill:#f4f6f8,stroke:#9aa4b2,stroke-width:2px,rx:18,ry:18
    classDef tool fill:#eceff1,stroke:#b0bec5,stroke-width:1.2px,rx:10,ry:10
    classDef terminal fill:#263238,color:#ffffff,stroke:#263238,stroke-width:2px,rx:15,ry:15

    class START,END_OK,END_FORCED terminal
    class GRADE_DOCS,REWRITE,GENERATE,GRADE_GEN agent
    class RETRIEVE,FORCED_GEN,FORCED_END module
    class ROUTE_GRADE,ROUTE_GEN,MAXCHECK_GRADE,MAXCHECK_GEN decision
